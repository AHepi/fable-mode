---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/newsreader';
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { url } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}
const { title, description, wide = false } = Astro.props;
const siteName = 'Fable Academy';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {siteName}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={url('favicon.svg')} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={url()}>{siteName}</a>
        <span class="tagline">Courses, written to be read.</span>
      </div>
    </header>
    <main class:list={['page', wide && 'page--wide']}>
      <slot />
    </main>
    <footer class="footer">
      <div class="bar">Every course here is plain Markdown, researched and written by an automated pipeline.</div>
    </footer>
  </body>
</html>
