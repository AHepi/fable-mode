---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/newsreader';
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { url } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  /** HSL channel string, e.g. "172 66% 50%" — tints the page in a subject hue. */
  subjectHue?: string;
}
const { title, description, wide = false, subjectHue } = Astro.props;
const siteName = 'Fable Academy';

const path = Astro.url.pathname;
const is = (seg: string) => path.includes(`/${seg}`);
const nav = [
  { href: url('browse'), label: 'Browse', on: is('browse') },
  { href: url('subjects'), label: 'Subjects', on: is('subjects') },
  { href: url('paths'), label: 'Paths', on: is('paths') },
];
const bodyStyle = subjectHue ? `--subject:${subjectHue}` : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {siteName}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={url('favicon.svg')} type="image/svg+xml" />
  </head>
  <body style={bodyStyle}>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={url()}><span class="spark"></span><span class="label">{siteName}</span></a>
        <nav class="nav">
          {nav.map((n) => <a href={n.href} aria-current={n.on ? 'page' : undefined}>{n.label}</a>)}
        </nav>
      </div>
    </header>
    <main class:list={['page', wide && 'page--wide']}>
      <slot />
    </main>
    <footer class="footer">
      <div class="bar">
        <span>Fable Academy — courses researched and written by an automated pipeline.</span>
        <nav>
          <a href={url('browse')}>Browse</a>
          <a href={url('subjects')}>Subjects</a>
          <a href={url('paths')}>Paths</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
