---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { url } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  /** HSL channel string, e.g. "172 60% 48%" — tints the page in a subject accent. */
  subjectHue?: string;
}
const { title, description, wide = false, subjectHue } = Astro.props;
const siteName = 'Fable Academy';

const path = Astro.url.pathname;
const is = (seg: string) => path.includes(`/${seg}`);
const nav = [
  { href: url('browse'), label: 'Browse', on: is('browse') },
  { href: url('subjects'), label: 'Subjects', on: is('subjects') },
  { href: url('paths'), label: 'Paths', on: is('paths') },
  { href: url('how-it-works'), label: 'How it works', on: is('how-it-works') },
];
void subjectHue; // accent is unified to hazard red; per-subject hue intentionally ignored
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {siteName}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={url('favicon.svg')} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={url()}><span class="spark"></span><span class="label">{siteName}</span></a>
        <nav class="nav">
          {nav.map((n) => <a href={n.href} aria-current={n.on ? 'page' : undefined}>{n.label}</a>)}
        </nav>
      </div>
    </header>
    <main class:list={['page', wide && 'page--wide']}>
      <slot />
    </main>
    <footer class="footer">
      <div class="bar">
        <span>Fable Academy. Courses researched and written by an automated pipeline.</span>
        <nav>
          <a href={url('browse')}>Browse</a>
          <a href={url('subjects')}>Subjects</a>
          <a href={url('paths')}>Paths</a>
          <a href={url('how-it-works')}>How it works</a>
        </nav>
      </div>
    </footer>

    <script>
      // Tasteful, motivated reveal: fade blocks in as they enter view.
      // IntersectionObserver only (no scroll listener); fully skipped under reduced-motion.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const sel = '.card, .subject-tile, .path-card, .section-head';
        const els = Array.from(document.querySelectorAll(sel));
        els.forEach((el) => el.classList.add('reveal'));
        document.querySelectorAll('.catalog-grid, .subject-grid').forEach((grid) => {
          Array.from(grid.children).forEach((c, i) =>
            (c as HTMLElement).style.setProperty('--rev-i', String(i % 6)),
          );
        });
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -6% 0px', threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
