---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { url, courseUrl, moduleUrl } from '../../../lib/url';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  const modules = await getCollection('modules');

  return modules.map((entry) => {
    const slug = entry.id.split('/')[0];
    const moduleId = entry.id.split('/').slice(1).join('/');
    const course = courses.find((c) => c.id.split('/')[0] === slug);
    const siblings = modules
      .filter((m) => m.id.split('/')[0] === slug)
      .sort((a, b) => a.data.order - b.data.order);
    const idx = siblings.findIndex((m) => m.id === entry.id);
    return {
      params: { course: slug, module: moduleId },
      props: { entry, courseTitle: course?.data.title ?? slug, siblings, idx },
    };
  });
}

const { entry, courseTitle, siblings, idx } = Astro.props;
const slug = entry.id.split('/')[0];
const { Content } = await render(entry);
const { data } = entry;
const mid = (m: { id: string }) => m.id.split('/').slice(1).join('/');
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx < siblings.length - 1 ? siblings[idx + 1] : null;
---

<Base title={data.title} description={data.summary} wide>
  <p class="crumbs">
    <a href={url()}>Catalog</a><span class="sep">/</span>
    <a href={courseUrl(slug)}>{courseTitle}</a><span class="sep">/</span>{data.title}
  </p>

  <div class="module-layout">
    <details class="toc" open>
      <summary class="toc-head">In this course</summary>
      <ol>
        {
          siblings.map((m) => (
            <li>
              <a href={moduleUrl(slug, mid(m))} class={m.id === entry.id ? 'current' : ''}>
                {String(m.data.order).padStart(2, '0')}. {m.data.title}
              </a>
            </li>
          ))
        }
      </ol>
    </details>

    <article>
      <p class="eyebrow">Module {data.order} of {siblings.length}</p>
      <h1>{data.title}</h1>

      {
        data.objectives.length > 0 && (
          <div class="objectives">
            <strong>What you'll be able to do</strong>
            <ul>{data.objectives.map((o) => <li>{o}</li>)}</ul>
          </div>
        )
      }

      <div class="prose"><Content /></div>

      <nav class="pager">
        {
          prev ? (
            <a class="prev" href={moduleUrl(slug, mid(prev))}>
              <span class="dir">← Previous</span>
              {prev.data.title}
            </a>
          ) : (
            <span class="spacer" />
          )
        }
        {
          next ? (
            <a class="next" href={moduleUrl(slug, mid(next))}>
              <span class="dir">Next →</span>
              {next.data.title}
            </a>
          ) : (
            <span class="spacer" />
          )
        }
      </nav>
    </article>
  </div>
</Base>
