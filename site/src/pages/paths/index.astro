---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url, courseUrl, seriesUrl, pathUrl } from '../../lib/url';
import { subjectHue, slugOf } from '../../lib/taxonomy';

const allPaths = await getCollection('paths');
const allCourses = await getCollection('courses');

// Build course slug -> { title } lookup
const courseMap = new Map<string, { title: string; subject?: string }>();
for (const c of allCourses) {
  const slug = slugOf(c.id);
  if (!courseMap.has(slug)) {
    courseMap.set(slug, { title: c.data.title, subject: c.data.subject ?? undefined });
  }
}

// Build seriesSlug -> seriesTitle lookup
const seriesMap = new Map<string, string>();
for (const c of allCourses) {
  const s = c.data.series;
  if (s?.slug && s?.title && !seriesMap.has(s.slug)) {
    seriesMap.set(s.slug, s.title);
  }
}

const paths = allPaths.sort((a, b) => a.data.order - b.data.order);
---

<Base title="Paths" description="Curated routes through several courses toward a real capability." wide>
  <p class="crumbs"><a href={url()}>Catalog</a><span class="sep">/</span>Paths</p>

  <p class="eyebrow">Specialisation paths</p>
  <h1>Paths</h1>
  <p class="lead">Curated routes through several courses toward a real capability.</p>

  {paths.map((p) => {
    const hue = subjectHue(p.data.subject ?? undefined);
    const steps = p.data.steps;
    return (
      <div class="path-card" style={`--subject:${hue}`}>
        <span class="chip subject">
          <span class="dot"></span>
          {p.data.subject ?? 'Path'}
        </span>

        <h3><a href={pathUrl(p.id)}>{p.data.title}</a></h3>
        <p>{p.data.blurb}</p>

        <ol class="track">
          {steps.map((step, i) => {
            let title: string;
            let href: string;
            if (step.course) {
              title = courseMap.get(step.course)?.title ?? step.course;
              href = courseUrl(step.course);
            } else if (step.series) {
              title = seriesMap.get(step.series) ?? step.series;
              href = seriesUrl(step.series);
            } else {
              title = '';
              href = '#';
            }
            return (
              <li>
                <span class="node">{i + 1}</span>
                <div class="step-title"><a href={href}>{title}</a></div>
                {step.note && <div class="step-note">{step.note}</div>}
              </li>
            );
          })}
        </ol>

        <div class="badges">
          <span class="badge">{steps.length} courses</span>
        </div>
      </div>
    );
  })}
</Base>

<style>
  /* ---- path card ---- */
  .path-card {
    --accent-path: hsl(var(--subject, 231 100% 71%));
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent-path);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 1.6rem;
  }
  .path-card h3 { margin: 0; font-size: 1.3rem; line-height: 1.2; }
  .path-card h3 a { color: var(--text); }
  .path-card h3 a:hover { color: var(--accent-path); text-decoration: none; }
  .path-card > p { font-family: var(--font-read); color: var(--text-dim); font-size: 1rem; line-height: 1.5; margin: 0; }

  /* ---- chip ---- */
  .chip {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: hsl(var(--subject, 231 100% 71%));
    background: color-mix(in srgb, hsl(var(--subject, 231 100% 71%)) 12%, transparent);
    border: 1px solid color-mix(in srgb, hsl(var(--subject, 231 100% 71%)) 30%, var(--border));
    border-radius: 999px;
    padding: 0.18rem 0.7rem 0.18rem 0.5rem;
    align-self: flex-start;
  }
  .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; flex-shrink: 0;
  }

  /* ---- track ---- */
  .track { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .track li { display: grid; grid-template-columns: 1.8rem 1fr; grid-template-rows: auto auto; column-gap: 0.6rem; align-items: start; }
  .node {
    grid-row: 1 / 3;
    display: flex; align-items: center; justify-content: center;
    width: 1.6rem; height: 1.6rem; border-radius: 50%;
    background: color-mix(in srgb, var(--accent-path, var(--accent)) 15%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent-path, var(--accent)) 35%, var(--border));
    color: var(--accent-path, var(--accent));
    font-size: 0.72rem; font-weight: 700; font-variant-numeric: tabular-nums;
    flex-shrink: 0; margin-top: 0.1rem;
  }
  .step-title { font-weight: 600; font-size: 0.92rem; line-height: 1.3; color: var(--text); }
  .step-title a { color: inherit; }
  .step-title a:hover { color: var(--accent-path, var(--accent)); }
  .step-note { grid-column: 2; font-size: 0.82rem; color: var(--muted); line-height: 1.4; margin-top: 0.1rem; }
</style>
