---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url, subjectUrl } from '../../lib/url';
import {
  SUBJECT_ORDER,
  subjectHue,
  subjectBlurb,
  subjectSlug,
} from '../../lib/taxonomy';

const courses = await getCollection('courses');

// Count courses per subject.
const counts = new Map<string, number>();
for (const c of courses) {
  const s = c.data.subject;
  if (s) counts.set(s, (counts.get(s) ?? 0) + 1);
}

// Only subjects that have at least one course.
const subjects = SUBJECT_ORDER.filter((s) => counts.has(s));
---

<Base title="Subjects" description="Browse the Fable Academy library by discipline." wide>
  <nav class="crumbs">
    <a href={url('browse')}>Catalog</a>
    <span class="sep">›</span>
    <span>Subjects</span>
  </nav>

  <h1>Subjects</h1>
  <p class="lead">Pick a discipline and explore every course within it, ranked by difficulty.</p>

  <div class="subject-grid">
    {subjects.map((s) => {
      const n = counts.get(s)!;
      return (
        <a
          class="subject-tile"
          href={subjectUrl(subjectSlug(s))}
          style={`--subject:${subjectHue(s)}`}
        >
          <h3>{s}</h3>
          <p>{subjectBlurb(s)}</p>
          <span class="count">{n} {n === 1 ? 'course' : 'courses'} →</span>
        </a>
      );
    })}
  </div>
</Base>
