---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { url, courseUrl, pathUrl, subjectUrl } from '../lib/url';
import {
  SUBJECT_ORDER, subjectHue, subjectBlurb, subjectSlug,
  levelLabel, slugOf,
} from '../lib/taxonomy';

const courses = await getCollection('courses');
const paths = (await getCollection('paths')).sort((a, b) => a.data.order - b.data.order);

// Subjects that actually have courses, with counts.
const counts = new Map<string, number>();
for (const c of courses) {
  const s = c.data.subject;
  if (s) counts.set(s, (counts.get(s) ?? 0) + 1);
}
const subjects = SUBJECT_ORDER.filter((s) => counts.has(s));

// "Start here" — essentials primers + standalone beginner courses, a curated few.
const starters = courses
  .filter((c) => c.data.series?.role === 'essentials' || (!c.data.series && c.data.level === 'intro'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 6);
---

<Base title="Catalog" description="A growing library of courses, researched and written by an automated pipeline." wide>
  <section class="hero">
    <p class="eyebrow">Fable Academy</p>
    <h1>Learn a subject the way it deserves to be taught.</h1>
    <p class="lead">
      Researched, written, and edited end to end. Organised by subject, difficulty, and path.
    </p>
    <div class="hero-actions">
      <a class="btn btn--primary" href={url('browse')}>Browse all courses →</a>
      <a class="btn" href={url('paths')}>See the paths</a>
    </div>
  </section>

  {paths.length > 0 && (
    <>
      <div class="section-head"><h2>Specialisation paths</h2><a class="more" href={url('paths')}>All paths →</a></div>
      <div class="catalog-grid">
        {paths.map((p) => (
          <a class="card" href={pathUrl(p.id)} style={`--subject:${subjectHue(p.data.subject)}`}>
            <p class="kicker">{p.data.subject ?? 'Path'}</p>
            <h3>{p.data.title}</h3>
            <p class="desc">{p.data.blurb}</p>
            <div class="badges"><span class="badge subject">Path</span><span class="badge">{p.data.steps.length} courses</span></div>
          </a>
        ))}
      </div>
    </>
  )}

  <div class="section-head"><h2>Browse by subject</h2><a class="more" href={url('subjects')}>All subjects →</a></div>
  <div class="subject-grid">
    {subjects.map((s) => (
      <a class="subject-tile" href={subjectUrl(subjectSlug(s))} style={`--subject:${subjectHue(s)}`}>
        <h3>{s}</h3>
        <p>{subjectBlurb(s)}</p>
        <span class="count">{counts.get(s)} {counts.get(s) === 1 ? 'course' : 'courses'} →</span>
      </a>
    ))}
  </div>

  {starters.length > 0 && (
    <>
      <div class="section-head"><h2>Good places to start</h2><a class="more" href={url('browse')}>Browse all →</a></div>
      <div class="catalog-grid">
        {starters.map((course) => {
          const slug = slugOf(course.id);
          return (
            <a class="card" href={courseUrl(slug)} style={`--subject:${subjectHue(course.data.subject)}`}>
              {course.data.subject && <p class="kicker">{course.data.subject}</p>}
              <h3>{course.data.title}</h3>
              <p class="desc">{course.data.description}</p>
              <div class="badges">
                <span class="badge level">{levelLabel(course.data.level)}</span>
                <span class="badge">{course.data.moduleOrder.length} modules</span>
                <span class="badge">~{course.data.estimatedHours}h</span>
              </div>
            </a>
          );
        })}
      </div>
    </>
  )}
</Base>
